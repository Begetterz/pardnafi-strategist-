# Network RPCs
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
OPBNB_TESTNET_RPC_URL=https://opbnb-testnet-rpc.bnbchain.org

# Deployment key (never commit a real key)
DEPLOYER_PRIVATE_KEY=YOUR_PRIVATE_KEY

# Explorer API keys for verify commands
BSCSCAN_API_KEY=YOUR_BSCSCAN_API_KEY
OPBNBSCAN_API_KEY=YOUR_OPBNBSCAN_API_KEY

# Used by publish-sample-strategy.js after deployment
REGISTRY_ADDRESS=0xYourDeployedRegistryAddress
PROTOCOL_NAME=Venus
EXPECTED_APY_BPS=820
RISK_SCORE=2
STRATEGY_CHAIN_ID=97
STRATEGY_HASH_SEED=venus-usdt-stability
